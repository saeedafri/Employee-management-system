{
  "name": "employee-management-system-backend",
  "version": "1.0.0",
  "description": "Production-grade Employee Management System backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "NODE_ENV=development node --watch src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:seed:comprehensive": "node prisma/seedComprehensive.js",
    "db:seed:large": "node prisma/seedLargeDemo.js",
    "db:seed:production": "node prisma/seedProductionData.js",
    "db:seed:demo": "node prisma/seedDemo.js",
    "db:studio": "prisma studio",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.js\"",
    "email:test": "node scripts/sendTestEmail.js",
    "seed:test-email-user": "node scripts/seedTestEmailUser.js",
    "api:capture": "node scripts/captureApiResponses.js",
    "perf:api": "node scripts/perfApiSmoke.js",
    "db:seed:photos": "node prisma/seedPhotos.js",
    "db:seed:ui": "node prisma/seedUIData.js",
    "db:seed:payroll": "node prisma/seedPayroll.mjs",
    "db:seed:phase3": "node prisma/seedPhase3Rich.js",
    "db:seed:phase3:payroll": "node prisma/seedPayrollPhase3.js",
    "db:seed:timesheets": "node prisma/seedTimesheets.js",
    "db:seed:integrations": "node prisma/seedPhase3Integrations.js",
    "test:deployed-ui:smoke": "node scripts/deployed-ui-full-audit.mjs",
    "test:deployed-ui:deep": "node scripts/deployed-ui-deep-clickthrough.mjs",
    "test:deployed-ui": "node scripts/deployed-ui-complete-final-audit.mjs",
    "test:playwright:deployed": "playwright test tests/e2e/deployed-full-clickthrough.spec.ts --project=chromium --workers=1",
    "db:seed:deep": "node prisma/seedDeepClickthrough.js",
    "seed:production-api": "node scripts/seedProductionViaApi.mjs",
    "verify:phase3-production": "node scripts/verifyPhase3Production.mjs",
    "db:seed:payroll-contract": "node scripts/seedPayrollContractData.mjs",
    "verify:payroll-contract": "node scripts/verifyPayrollLiveContract.mjs",
    "test:smoke": "node --test tests/bootstrap.smoke.test.js",
    "test:auth-me": "node --test tests/auth-me.test.js",
    "test:auth-logout": "node --test tests/auth-logout.test.js",
    "verify:auth-logout:live": "node scripts/verifyAuthLogoutLive.mjs",
    "test:playwright:logout": "npx playwright test tests/e2e/logout-security.spec.ts --project=chromium --workers=1",
    "verify:logout-ui": "node scripts/verifyLogoutUiPlaywright.mjs"
  },
  "keywords": [
    "employee-management",
    "hrms",
    "fastify",
    "prisma"
  ],
  "author": "Mohd Saeed Afri",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.1.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.15.0",
    "argon2": "^0.31.2",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^4.26.1",
    "jose": "^5.4.1",
    "nodemailer": "^8.0.7",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@playwright/test": "^1.60.0",
    "eslint": "^8.57.0",
    "globals": "^14.0.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.60.0",
    "prettier": "^3.2.5",
    "prisma": "^5.15.0"
  },
  "engines": {
    "node": "20.x"
  }
}
