{
  "name": "employee-management-system-backend",
  "version": "1.0.0",
  "description": "Production-grade Employee Management System backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "NODE_ENV=development node --watch src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:seed:large": "node prisma/seedLargeDemo.js",
    "db:seed:production": "node prisma/seedProductionData.js",
    "db:studio": "prisma studio",
    "test:performance": "mocha 'tests/performance.test.js'",
    "test": "mocha 'tests/**/*.test.js'",
    "test:unit": "mocha 'tests/unit/**/*.test.js'",
    "test:integration": "mocha 'tests/integration/**/*.test.js'",
    "test:e2e": "mocha 'tests/e2e/**/*.test.js'",
    "test:watch": "mocha 'tests/**/*.test.js' --watch",
    "test:coverage": "c8 mocha 'tests/**/*.test.js'",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"prisma/**/*.js\"",
    "email:test": "node scripts/sendTestEmail.js",
    "seed:test-email-user": "node scripts/seedTestEmailUser.js",
    "api:capture": "node scripts/captureApiResponses.js",
    "perf:api": "node scripts/perfApiSmoke.js"
  },
  "keywords": [
    "employee-management",
    "hrms",
    "fastify",
    "prisma"
  ],
  "author": "Mohd Saeed Afri",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.15.0",
    "argon2": "^0.31.2",
    "bullmq": "^5.14.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.5",
    "jose": "^5.4.1",
    "nodemailer": "^8.0.7",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "redis": "^5.12.1",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@faker-js/faker": "^8.4.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^8.57.0",
    "globals": "^14.0.0",
    "mocha": "^11.7.5",
    "node-fetch": "^2.7.0",
    "prettier": "^3.2.5",
    "prisma": "^5.15.0",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
