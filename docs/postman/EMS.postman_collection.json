{
  "info": {
    "_postman_id": "ems-backend-collection",
    "name": "EMS Backend API",
    "description": "Employee Management System Backend API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Tenant-Key", "value": "{{tenantKey}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"email\": \"test@example.com\", \"password\": \"password\"}"},
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "GET Current User",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "X-Tenant-Key", "value": "{{tenantKey}}"}
            ],
            "url": {"raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"]}
          }
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "X-Tenant-Key", "value": "{{tenantKey}}"}
            ],
            "url": {"raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"]}
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "X-Tenant-Key", "value": "{{tenantKey}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/logs?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "logs"],
              "query": [{"key": "limit", "value": "50"}]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000/api/v1"},
    {"key": "tenantKey", "value": "test-tenant"},
    {"key": "accessToken", "value": ""}
  ]
}
