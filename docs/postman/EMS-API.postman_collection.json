  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {pm.response.to.have.status(200);});",
                  "pm.test('Response has accessToken', function() {var data = pm.response.json(); pm.expect(data.data).to.have.property('accessToken');});",
                  "pm.test('Response has sessionId', function() {var data = pm.response.json(); pm.expect(data.data).to.have.property('sessionId'); pm.environment.set('session_id', data.data.sessionId);});",
                  "pm.test('Response has user', function() {var data = pm.response.json(); pm.expect(data.data).to.have.property('user');});",
                  "pm.test('Save access token', function() {var data = pm.response.json(); pm.environment.set('access_token', data.data.accessToken);}); "
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-key",
                "value": "{{tenant_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{employee_email}}\",\"password\":\"{{employee_password}}\"}"
            },
            "url": {
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
