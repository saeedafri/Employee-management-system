# Local TEST environment — copy to `.env.test` (gitignored). Never commit real secrets.
#
# ⛔ DATABASE_URL MUST be local. The safety guard (.claude/hooks/ems-safety-guard.cjs)
#    blocks the test suite unless DATABASE_URL targets localhost/127.0.0.1 or a DB
#    named with `ems_test`. NEVER set this to the Hostinger/Render production URL.
NODE_ENV=test
DATABASE_URL=postgresql://ems:ems_local_dev@127.0.0.1:5432/ems_test?sslmode=disable

# For local DEV (not tests) use the ems_dev database:
#   DATABASE_URL=postgresql://ems:ems_local_dev@127.0.0.1:5432/ems_dev?sslmode=disable

JWT_SECRET=test-secret-not-for-production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
