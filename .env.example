# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="mysql://user:password@localhost:3306/employee-management"

# Redis
REDIS_URL="redis://127.0.0.1:6379"

# JWT Tokens
JWT_SECRET="change-this-to-a-secure-random-string-min-32-characters"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# CORS Origins
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Email (SMTP for BullMQ)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@acme.test"

# Application Metadata
APP_NAME="EMS"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"

# Session & Cookies
SESSION_COOKIE_NAME="refreshToken"
SESSION_MAX_AGE_DAYS=7

# Tenant Resolution (for local dev)
DEFAULT_TENANT_KEY="acme"
TENANT_RESOLUTION_MODE="header"
