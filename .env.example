# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="mysql://user:password@localhost:3306/employee-management"

# Redis
REDIS_URL="redis://127.0.0.1:6379"

# JWT Tokens
JWT_SECRET="change-this-to-a-secure-random-string-min-32-characters"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# CORS Origins
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Email Provider ('smtp' | 'mock')
# 'smtp' = production Brevo or local SMTP server
# 'mock' = console logging only (dev testing)
EMAIL_PROVIDER="smtp"

# SMTP Configuration (Brevo)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="ab99cb001@smtp-brevo.com"
SMTP_PASS=""
SMTP_FROM="EMS <verified-sender@yourdomain.com>"

# Application Metadata
APP_NAME="EMS"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"

# Session & Cookies
SESSION_COOKIE_NAME="refreshToken"
SESSION_MAX_AGE_DAYS=7

# Reset Password
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
RESET_PASSWORD_RATE_LIMIT_MAX=5
RESET_PASSWORD_RATE_LIMIT_WINDOW="15 minutes"
FRONTEND_RESET_PASSWORD_URL="http://localhost:5173/reset-password"

# Tenant Resolution (for local dev)
DEFAULT_TENANT_KEY="acme"
TENANT_RESOLUTION_MODE="header"
