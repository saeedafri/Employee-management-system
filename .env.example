NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="mysql://ems_user:ems_pass_local@localhost:3306/ems_local"

# Redis
REDIS_URL="redis://127.0.0.1:6379"

# JWT
JWT_SECRET="your_super_secret_jwt_key_change_in_production_at_least_32_chars"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Email (BullMQ job processor config)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@acme.test"

# App
APP_NAME="EMS"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"

# Session
SESSION_COOKIE_NAME="refreshToken"
SESSION_MAX_AGE_DAYS=7
