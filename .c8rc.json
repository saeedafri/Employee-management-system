{
  "all": true,
  "include": ["src/**/*.js"],
  "exclude": ["src/**/*.test.js", "node_modules/**"],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "report-dir": "coverage",
  "temp-dir": ".nyc_output",
  "statements": 90,
  "branches": 85,
  "functions": 90,
  "lines": 90,
  "skip-full": false,
  "check-coverage": true
}
