        { "name": "Dashboard — Manager (GET /manager/dashboard)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/manager/dashboard", "host": ["{{baseUrl}}"], "path": ["manager", "dashboard"] } } },
