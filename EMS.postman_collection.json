        { "name": "Create employee", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"employeeCode\": \"EMP-PM-01\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Test\",\n  \"workEmail\": \"postman.test@testorg.com\",\n  \"designation\": \"Engineer\",\n  \"joinedOn\": \"2026-01-01\",\n  \"employmentType\": \"FULL_TIME\"\n}" }, "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] } } },
        { "name": "Export employees CSV", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/employees/export/csv", "host": ["{{baseUrl}}"], "path": ["employees", "export", "csv"] } } }
