model EmployeeLoan {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  amount      Decimal  @db.Decimal(15, 2)
  balance     Decimal  @db.Decimal(15, 2)
  emiAmount   Decimal  @db.Decimal(15, 2)
  startPeriod String
  endPeriod   String?
  status      String   @default("ACTIVE")
  schedule    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
}

model PayrollInput {
  id                String   @id @default(cuid())
  tenantId          String
  runId             String
  employeeId        String
  lopDays           Float    @default(0)
  otHours           Float    @default(0)
  variablePay       Decimal? @db.Decimal(15, 2)
  oneTimeAdditions  Json?
  oneTimeDeductions Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run      PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

