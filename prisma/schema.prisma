// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum MemberType {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
  AUDITOR
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
  LOCKED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum WorkMode {
  OFFICE
  WFH
  HYBRID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  WFH
  HALF_DAY
  HOLIDAY
}

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AttendanceRegularizationStatus {
  PENDING
  APPROVED
  DENIED
  WITHDRAWN
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  DENIED
  WITHDRAWN
  CANCELLED
}

enum ResignationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ReportFrequency {
  WEEKLY
  MONTHLY
}

enum ReportExportStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ExportJobStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
}

enum ExportType {
  EMPLOYEES
  ATTENDANCE
  LEAVE
}

enum RegularizationType {
  LATE
  MISSED_CHECKOUT
  EARLY_CHECKOUT
  OTHER
}

enum ComponentType {
  EARNING
  DEDUCTION
  BENEFIT
  REIMBURSEMENT
  EMPLOYER_CONTRIBUTION
  VARIABLE
}

enum CalculationType {
  FLAT
  PERCENTAGE
  FORMULA
}

enum PaySchedule {
  MONTHLY
  SEMI_MONTHLY
  BIWEEKLY
  WEEKLY
}

enum PayrollRunStatus {
  DRAFT
  CALCULATING
  REVIEW
  APPROVED
  PAID
  CANCELLED
}

enum PayslipStatus {
  PENDING
  PAID
  HELD
}

// Models
model Tenant {
  id                  String    @id @default(cuid())
  tenantKey           String    @unique // For header-based tenant resolution
  slug                String?   @unique // For subdomain-based tenant resolution
  name                String
  legalName           String
  displayName         String
  country             String
  defaultCurrency     String    @default("INR")
  timezone            String    @default("Asia/Kolkata")
  fiscalYearStart     Int       @default(4) // April 1
  primaryContactEmail String
  supportPhone        String?
  logoUrl             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  // Relations
  users                     User[]
  employees                 Employee[]
  departments               Department[]
  roles                     Role[]
  sessions                  Session[]
  passwordResetTokens       PasswordResetToken[]
  otpChallenges             OtpChallenge[]
  employeeDocuments         EmployeeDocument[]
  attendanceRecords         AttendanceRecord[]
  attendanceRegularizations AttendanceRegularizationRequest[]
  leaveTypes                LeaveType[]
  leaveBalances             LeaveBalance[]
  leaveRequests             LeaveRequest[]
  holidays                  Holiday[]
  resignations              Resignation[]
  auditLogs                 AuditLog[]
  logEntries                LogEntry[]
  notifications             Notification[]
  savedViews                SavedView[]
  settings                  Setting[]
  scheduledReports          ScheduledReport[]
  reportExports             ReportExport[]
  exportJobs                ExportJob[]
  tenantConfigs             TenantConfig[]
  emailTemplates            EmailTemplate[]
  salaryComponents          SalaryComponent[]
  payGroups                 PayGroup[]
  employeeSalaries          EmployeeSalary[]
  payrollRuns               PayrollRun[]
  payslips                  Payslip[]
  jobOpenings               JobOpening[]
  candidates                Candidate[]
  performanceCycles         PerformanceCycle[]
  performanceReviews        PerformanceReview[]
  performanceGoals          PerformanceGoal[]
  assets                    Asset[]
  assetRequests             AssetRequest[]
  announcementChannels      AnnouncementChannel[]
  announcements             Announcement[]
  announcementEvents        AnnouncementEvent[]
  timesheetProjects         TimesheetProject[]
  timesheetTasks            TimesheetTask[]
  timesheets                Timesheet[]
  timeEntries               TimeEntry[]
  timesheetSettings         TimesheetSettings?
  legalEntities             LegalEntity[]
  statutoryPacks            StatutoryPack[]
  payCalendars              PayCalendar[]
  taxDeclarations           TaxDeclaration[]
  employeeLoans             EmployeeLoan[]
  payrollInputs             PayrollInput[]
  openingBalances           OpeningBalance[]
  historicalPayslips        HistoricalPayslip[]
  migrationStatus           MigrationStatus?
  ReimbursementCategory     ReimbursementCategory[]
  ReimbursementClaim        ReimbursementClaim[]
  Garnishment               Garnishment[]
  ContractorInvoice         ContractorInvoice[]
  PaymentBatch              PaymentBatch[]
  PayrollEvent              PayrollEvent[]
  PayslipTemplate           PayslipTemplate?
  userInvitations           UserInvitation[]
  timesheetTemplates        TimesheetTemplate[]

  @@index([deletedAt])
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  employeeId   String?    @unique
  email        String
  passwordHash String
  memberType   MemberType @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  mfaEnabled   Boolean    @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Relations
  tenant                  Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee                Employee?
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  otpChallenges           OtpChallenge[]
  userRoles               UserRole[]
  auditLogs               AuditLog[]
  logEntries              LogEntry[]
  uploadedDocuments       EmployeeDocument[]                @relation("uploadedBy")
  verifiedDocuments       EmployeeDocument[]                @relation("verifiedBy")
  reviewedRegularizations AttendanceRegularizationRequest[] @relation("reviewer")
  approvedLeaves          LeaveRequest[]                    @relation("approver")
  reviewedResignations    Resignation[]                     @relation("reviewer")
  notifications           Notification[]
  savedViews              SavedView[]
  settingsUpdatedBy       Setting[]                         @relation("updatedBy")
  initiatedPayrollRuns    PayrollRun[]                      @relation("runInitiatedBy")
  approvedPayrollRuns     PayrollRun[]                      @relation("runApprovedBy")
  invitations             UserInvitation[]                  @relation("invitedUser")
  createdInvitations      UserInvitation[]                  @relation("inviteCreator")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([deletedAt])
}

model Employee {
  id                    String           @id @default(cuid())
  tenantId              String
  userId                String?          @unique
  employeeCode          String
  firstName             String
  lastName              String
  workEmail             String
  personalEmail         String?
  phone                 String?
  dateOfBirth           DateTime?
  gender                Gender?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  designation           String?
  departmentId          String?
  managerId             String?
  joinedOn              DateTime
  employmentType        EmploymentType   @default(FULL_TIME)
  employmentStatus      EmploymentStatus @default(ACTIVE)
  location              String?
  profilePhotoUrl       String?
  payCurrency           String           @default("INR")
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  // Relations
  tenant                    Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                      User?                             @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  department                Department?                       @relation("employees", fields: [departmentId], references: [id], onDelete: SetNull)
  manager                   Employee?                         @relation("managedBy", fields: [managerId], references: [id], onDelete: SetNull)
  managedEmployees          Employee[]                        @relation("managedBy")
  managedDepartments        Department[]                      @relation("headEmployee")
  documents                 EmployeeDocument[]
  attendanceRecords         AttendanceRecord[]
  attendanceRegularizations AttendanceRegularizationRequest[]
  leaveBalances             LeaveBalance[]
  leaveRequests             LeaveRequest[]
  resignations              Resignation[]
  salaries                  EmployeeSalary[]
  payslips                  Payslip[]
  taxDeclarations           TaxDeclaration[]
  employeeLoans             EmployeeLoan[]
  payrollInputs             PayrollInput[]
  openingBalances           OpeningBalance[]
  historicalPayslips        HistoricalPayslip[]
  ReimbursementClaim        ReimbursementClaim[]
  Garnishment               Garnishment[]
  invitations               UserInvitation[]

  @@unique([tenantId, employeeCode])
  @@unique([tenantId, workEmail])
  @@index([tenantId])
  @@index([departmentId])
  @@index([managerId])
  @@index([deletedAt])
  @@index([tenantId, employmentStatus])
  @@index([tenantId, departmentId, employmentStatus])
}

model Department {
  id             String    @id @default(cuid())
  tenantId       String
  parentId       String?
  name           String
  departmentCode String?
  headEmployeeId String?   @unique
  depth          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent         Department?  @relation("subDepartments", fields: [parentId], references: [id], onDelete: SetNull)
  subDepartments Department[] @relation("subDepartments")
  headEmployee   Employee?    @relation("headEmployee", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  employees      Employee[]   @relation("employees")

  @@unique([tenantId, departmentCode])
  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String? // Null for global/system roles
  name      String
  key       String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  module      String
  description String?

  // Relations
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  tenantId         String
  sessionFamilyId  String // For tracking token rotation and reuse detection
  refreshTokenHash String // SHA-256 hash of refresh token
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  loginAt          DateTime  @default(now())
  lastSeenAt       DateTime  @updatedAt
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String? // LOGOUT, TOKEN_REUSE_DETECTED, ADMIN_REVOKE, etc.
  createdAt        DateTime  @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([tenantId, userId, revokedAt])
  @@index([sessionFamilyId, revokedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  tokenHash   String    @unique // SHA-256 hash
  expiresAt   DateTime
  usedAt      DateTime?
  createdByIp String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([userId, expiresAt])
  @@index([tenantId, tokenHash])
  @@index([expiresAt])
  @@index([usedAt])
}

model OtpChallenge {
  id                String    @id @default(cuid())
  userId            String
  tenantId          String
  challengeId       String    @unique // State reference, not the code itself
  codeHash          String // SHA-256 hash of 6-digit code
  purpose           String // LOGIN, EMAIL_VERIFY, PHONE_VERIFY, ACCOUNT_RECOVERY
  deliveryChannel   String // EMAIL, SMS
  destinationMasked String // Masked email/phone for display (e.g., "u***@test.com")
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5)
  resendCount       Int       @default(0)
  maxResends        Int       @default(3)
  lastSentAt        DateTime?
  lockedAt          DateTime?
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, challengeId])
  @@index([tenantId, userId, consumedAt])
  @@index([expiresAt])
  @@index([lockedAt])
}

model EmployeeDocument {
  id                 String                     @id @default(cuid())
  tenantId           String
  employeeId         String
  documentType       String
  fileName           String
  fileUrl            String?
  storageKey         String?
  mimeType           String?
  sizeBytes          Int?
  verificationStatus DocumentVerificationStatus @default(PENDING)
  uploadedById       String
  verifiedById       String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  // Relations
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("uploadedBy", fields: [uploadedById], references: [id])
  verifiedBy User?    @relation("verifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
}

model AttendanceRecord {
  id             String           @id @default(cuid())
  seqNo          Int              @default(autoincrement())
  tenantId       String
  employeeId     String
  attendanceDate DateTime
  checkInAt      DateTime?
  checkOutAt     DateTime?
  workMode       WorkMode         @default(OFFICE)
  status         AttendanceStatus @default(PRESENT)
  totalMinutes   Int?
  locationJson   Json? // Location data
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, attendanceDate])
  @@index([tenantId, attendanceDate])
  @@index([employeeId, attendanceDate])
  @@index([status])
  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, status, attendanceDate])
}

model AttendanceRegularizationRequest {
  id              String                         @id @default(cuid())
  seqNo           Int                            @default(autoincrement())
  tenantId        String
  employeeId      String
  attendanceDate  DateTime
  type            RegularizationType             @default(LATE)
  reason          String
  status          AttendanceRegularizationStatus @default(PENDING)
  reviewerId      String?
  reviewerComment String?
  documentUrl     String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User?    @relation("reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([tenantId, status, createdAt])
}

model LeaveType {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  code                String
  annualAllowance     Int      @default(0)
  carryForwardAllowed Boolean  @default(false)
  isPaid              Boolean  @default(true)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model LeaveBalance {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  leaveTypeId String
  balance     Int      @default(0)
  used        Int      @default(0)
  pending     Int      @default(0)
  updatedAt   DateTime @updatedAt

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, leaveTypeId])
  @@index([tenantId])
  @@index([employeeId])
}

model LeaveRequest {
  id              String             @id @default(cuid())
  seqNo           Int                @default(autoincrement())
  tenantId        String
  employeeId      String
  leaveTypeId     String
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  reason          String
  status          LeaveRequestStatus @default(PENDING)
  approverId      String?
  approverComment String?
  submittedAt     DateTime           @default(now())
  decidedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  approver  User?     @relation("approver", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([tenantId, status, startDate])
}

model Holiday {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  holidayDate DateTime
  location    String?
  isOptional  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([holidayDate])
}

model Resignation {
  id                       String            @id @default(cuid())
  tenantId                 String
  employeeId               String
  reason                   String
  preferredLastWorkingDate DateTime
  status                   ResignationStatus @default(PENDING)
  reviewerId               String?
  reviewerComment          String?
  submittedAt              DateTime          @default(now())
  decidedAt                DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User?    @relation("reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  actorUserId   String? // Nullable for system-generated actions
  action        String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, APPROVE, etc.
  entityType    String // Employee, LeaveRequest, etc.
  entityId      String
  oldValuesJson Json? // JSON data for change tracking
  newValuesJson Json? // JSON data for change tracking
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([action])
  @@index([tenantId, createdAt, action])
}

model LogEntry {
  id           String   @id @default(cuid())
  tenantId     String
  level        String // ERROR, WARN, INFO, DEBUG
  levelLabel   String // Error, Warning, Information, Debug
  levelColor   String // red, yellow, blue, gray
  module       String // auth, employees, attendance, etc.
  message      String
  requestId    String? // Associated request ID
  actorUserId  String? // User who triggered the log
  metadataJson Json? // Additional context
  createdAt    DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, level])
  @@index([tenantId, module])
  @@index([requestId])
}

model Notification {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  type         String // leave_approved, leave_rejected, etc.
  title        String
  message      String
  metadataJson Json? // JSON context data
  readAt       DateTime?
  expiresAt    DateTime? // TTL — auto-filtered after this time
  createdAt    DateTime  @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@index([userId, readAt])
  @@index([tenantId])
  @@index([userId])
  @@index([readAt])
}

model SavedView {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  module      String // employees, leave, attendance, etc.
  name        String
  filtersJson Json // JSON filters
  columnsJson Json? // JSON column visibility
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, module, name])
  @@index([tenantId])
  @@index([userId])
}

model Setting {
  id          String   @id @default(cuid())
  tenantId    String
  groupKey    String // workspace, people, security, etc.
  settingKey  String // company-name, leave-types, etc.
  valueJson   Json // JSON value
  updatedById String?
  updatedAt   DateTime @updatedAt

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy User?  @relation("updatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, groupKey, settingKey])
  @@index([tenantId])
}

model ScheduledReport {
  id              String          @id @default(cuid())
  tenantId        String
  createdById     String
  reportType      String // attendance, leaves, payroll
  frequency       ReportFrequency
  emailRecipients Json // Array of email strings
  nextRunDate     DateTime
  isActive        Boolean         @default(true)
  lastRunAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, nextRunDate])
}

model ReportExport {
  id           String             @id @default(cuid())
  tenantId     String
  createdById  String?
  reportType   String // attendance, leaves, payroll
  format       String // json, csv
  status       ReportExportStatus @default(PENDING)
  fileUrl      String?
  filePath     String?
  errorMessage String?
  createdAt    DateTime           @default(now())
  completedAt  DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model TenantConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  companyName       String
  timezone          String   @default("Asia/Kolkata")
  workingHoursStart String   @default("09:00") // HH:mm format
  workingHoursEnd   String   @default("18:00") // HH:mm format
  fiscalYearStart   Int      @default(4) // April = 4
  fiscalYearEnd     Int      @default(3) // March = 3
  inviteEmailTarget String   @default("PERSONAL") // PERSONAL | WORK
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  type      String // LEAVE_APPROVAL, LEAVE_REJECTION, ATTENDANCE_ALERT
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
}

model ExportJob {
  id           String          @id @default(cuid())
  tenantId     String
  jobId        String          @unique
  createdById  String?
  exportType   ExportType
  format       String // csv, excel, json
  status       ExportJobStatus @default(QUEUED)
  fileUrl      String?
  errorMessage String?
  filters      Json?
  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, jobId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ── Payroll Module ─────────────────────────────────────────────────────────────

model SalaryComponent {
  id              String          @id @default(cuid())
  tenantId        String
  name            String
  code            String
  type            ComponentType
  calculationType CalculationType
  value           Decimal?        @db.Decimal(15, 2)
  basisCode       String?
  formula         String?
  taxable         Boolean         @default(true)
  active          Boolean         @default(true)
  displayOrder    Int             @default(0)
  description     String?
  statutoryTag    String?
  prorate         Boolean         @default(true)
  payInPeriods    String? // JSON-encoded number[] | null
  glAccountCode   String?
  costCenterRule  String          @default("NONE") // DEPARTMENT | NONE
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payGroupComponents PayGroupComponent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, active])
}

model PayGroup {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  code        String
  currency    String      @default("INR")
  paySchedule PaySchedule @default(MONTHLY)
  description String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  components       PayGroupComponent[]
  employeeSalaries EmployeeSalary[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model PayGroupComponent {
  id                      String           @id @default(cuid())
  payGroupId              String
  componentId             String
  overrideCalculationType CalculationType?
  overrideValue           Decimal?         @db.Decimal(15, 2)
  overrideFormula         String?

  // Relations
  payGroup  PayGroup        @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  component SalaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([payGroupId, componentId])
  @@index([payGroupId])
  @@index([componentId])
}

model EmployeeSalary {
  id                String    @id @default(cuid())
  tenantId          String
  employeeId        String
  payGroupId        String
  annualCtc         Decimal   @db.Decimal(15, 2)
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  country           String?   @default("IN")
  currency          String?
  legalEntityId     String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankName          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payGroup PayGroup @relation(fields: [payGroupId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, employeeId, effectiveFrom])
  @@index([tenantId, country])
  @@index([tenantId, legalEntityId])
}

model PayrollRun {
  id               String           @id @default(cuid())
  tenantId         String
  period           String // "2024-06" | "2024-06-H1" | "2024-W23"
  startDate        DateTime?        // Cycle start date (Option B period model)
  endDate          DateTime?        // Cycle end date
  payDate          DateTime?        // Scheduled pay date
  paySchedule      String?          // MONTHLY | SEMI_MONTHLY | BIWEEKLY | WEEKLY
  type             String           @default("REGULAR") // REGULAR | OFF_CYCLE | BONUS | ARREARS | FNF | REVERSAL
  status           PayrollRunStatus @default(DRAFT)
  employeeCount    Int              @default(0)
  totalGross       Decimal          @default(0) @db.Decimal(15, 2)
  totalDeductions  Decimal          @default(0) @db.Decimal(15, 2)
  totalNet         Decimal          @default(0) @db.Decimal(15, 2)
  employerCost     Decimal          @default(0) @db.Decimal(15, 2)
  currency         String           @default("INR")
  initiatedById    String?
  approvedById     String?
  approvalNotes    String?
  paymentReference String?
  cancelReason     String?
  processedAt      DateTime?
  approvedAt       DateTime?
  paidAt           DateTime?
  published        Boolean          @default(false)
  publishedAt      DateTime?
  summaryJson      Json?
  approvalsJson    Json?
  auditJson        Json? // PayrollRunAuditEntry[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  initiatedByUser User?          @relation("runInitiatedBy", fields: [initiatedById], references: [id], onDelete: SetNull)
  approvedByUser  User?          @relation("runApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  payslips        Payslip[]
  inputs          PayrollInput[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, period])
}

model Payslip {
  id                    String        @id @default(cuid())
  tenantId              String
  payrollRunId          String
  employeeId            String
  period                String // "2024-06"
  currency              String        @default("INR")
  grossEarnings         Decimal       @default(0) @db.Decimal(15, 2)
  totalDeductions       Decimal       @default(0) @db.Decimal(15, 2)
  netPay                Decimal       @default(0) @db.Decimal(15, 2)
  workingDays           Int           @default(0)
  presentDays           Int           @default(0)
  leaveDays             Int           @default(0)
  lopDays               Int           @default(0)
  status                PayslipStatus @default(PENDING)
  heldAt                DateTime?
  holdReason            String?
  paymentDate           DateTime?
  paymentReference      String?
  earningsJson          Json?
  deductionsJson            Json?
  employerContributionsJson Json?
  oneTimeAdditionsJson      Json?
  oneTimeDeductionsJson     Json?
  notes                 String?
  documentUrl           String?
  generatedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([tenantId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([tenantId, period])
  @@index([status])
}

// ── Payroll Phase 3 Models ──────────────────────────────────────────────────────

model LegalEntity {
