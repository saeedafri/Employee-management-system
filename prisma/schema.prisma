model OpeningBalance {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  fiscalYear      String
  grossEarnings   Decimal  @db.Decimal(15, 2)
  taxableIncome   Decimal  @db.Decimal(15, 2)
  taxDeducted     Decimal  @db.Decimal(15, 2)
  totalDeductions Decimal  @db.Decimal(15, 2)
  netPay          Decimal  @db.Decimal(15, 2)
  contributions   Json     @default("{}")
  importedAt      DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, fiscalYear])
  @@index([tenantId])
}

model HistoricalPayslip {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  employeeCode    String
  period          String
  grossEarnings   Decimal  @db.Decimal(15, 2)
  totalDeductions Decimal  @db.Decimal(15, 2)
  netPay          Decimal  @db.Decimal(15, 2)
  importedAt      DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
}

model MigrationStatus {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  sandboxMode         Boolean  @default(true)
  goLivePeriod        String?
  lastReconciledRunId String?
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Recruitment Module ─────────────────────────────────────────────────────────

model JobOpening {
  id             String   @id @default(cuid())
  tenantId       String
  title          String
  department     String
  location       String
  employmentType String // FULL_TIME | PART_TIME | CONTRACT | INTERNSHIP
  applicantCount Int      @default(0)
  currentStage   String   @default("Applied")
  status         String   @default("Open") // Open | Closing | On hold | Closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  candidates Candidate[]
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Candidate {
  id          String   @id @default(cuid())
  tenantId    String
  openingId   String
  name        String
  role        String
  email       String
  stage       String   @default("applied") // applied | screening | interview | offer | hired
  rating      Int      @default(0) // 0-5
  daysInStage Int      @default(0)
  isReferral  Boolean  @default(false)
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  opening JobOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([openingId])
  @@index([tenantId, stage])
}

// ── Performance Module ─────────────────────────────────────────────────────────

model PerformanceCycle {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  selfReviewDue    DateTime
  managerReviewDue DateTime
  calibrationDate  DateTime
  progressPct      Int      @default(0)
  status           String   @default("In progress") // Upcoming | In progress | Calibrating | Closed
  startedAt        DateTime @default(now())

  // Relations
  reviews PerformanceReview[]
  goals   PerformanceGoal[]
  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model PerformanceReview {
  id              String   @id @default(cuid())
  tenantId        String
  cycleId         String
  employeeId      String
  reviewerId      String?
  status          String   @default("Not started") // Not started | Self review | Manager review | Calibrated
  rating          String? // Exceeds | Strong | Meets | Developing | Below
  selfComplete    Boolean  @default(false)
  managerComplete Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  cycle  PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cycleId, employeeId])
  @@index([tenantId])
  @@index([cycleId])
  @@index([employeeId])
}

model PerformanceGoal {
  id          String   @id @default(cuid())
  tenantId    String
  cycleId     String?
  employeeId  String
  title       String
  progressPct Int      @default(0)
  dueDate     DateTime
  status      String   @default("On track") // On track | At risk | Done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  cycle  PerformanceCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cycleId])
  @@index([employeeId])
}

// ── Assets Module ──────────────────────────────────────────────────────────────

model Asset {
  id             String   @id @default(cuid())
  tenantId       String
  tag            String
  name           String
  type           String // Laptop | Monitor | Phone | Other
  status         String   @default("Available") // Assigned | Available | Repair | Retired
  assignedToId   String?
  assignedToName String?
  assignedSince  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  requests AssetRequest[]
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tag])
  @@index([tenantId])
  @@index([tenantId, status])
}

model AssetRequest {
  id              String   @id @default(cuid())
  tenantId        String
  requestedById   String
  requestedByName String
  assetId         String?
  item            String
  reason          String
  status          String   @default("Pending") // Pending | Approved | Fulfilled | Declined
  declineReason   String?
  requestedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  asset  Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

// ── Announcements Module ───────────────────────────────────────────────────────

model AnnouncementChannel {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  category  String // Company | People | Product | IT | Office
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  announcements Announcement[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Announcement {
  id         String   @id @default(cuid())
  tenantId   String
  channelId  String
  category   String
  title      String
  body       String
  authorName String
  authorRole String?
  audience   String   @default("All employees")
  readCount  Int      @default(0)
  isPinned   Boolean  @default(false)
  postedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  channel AnnouncementChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isPinned])
  @@index([channelId])
}

model AnnouncementEvent {
  id        String   @id @default(cuid())
  tenantId  String
  date      String // YYYY-MM-DD
  title     String
  meta      String
  createdAt DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
}

// ─── Domain G: Timesheets ────────────────────────────────────────────────────

model TimesheetProject {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  clientName  String?
  status      String   @default("ACTIVE") // ACTIVE | ARCHIVED
  billable    Boolean  @default(true)
  defaultRate Float    @default(0)
  memberIds   String   @default("[]") // JSON-encoded array of employee IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks   TimesheetTask[]
  entries TimeEntry[]

  @@index([tenantId])
}

model TimesheetTask {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  name      String
  billable  Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project TimesheetProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@index([tenantId])
  @@index([projectId])
}

model Timesheet {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  weekStart   String // YYYY-MM-DD (Monday)
  weekEnd     String // YYYY-MM-DD (Sunday)
  status      String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED
  totalHours  Float     @default(0)
  submittedAt DateTime?
  decidedBy   String?
  decidedAt   DateTime?
  comment     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@unique([tenantId, employeeId, weekStart])
  @@index([tenantId])
  @@index([employeeId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  tenantId    String
  timesheetId String
  employeeId  String
  projectId   String
  taskId      String?
  date        String // YYYY-MM-DD
  hours       Float
  billable    Boolean  @default(true)
  note        String?
  source      String   @default("MANUAL") // MANUAL | TIMER
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timesheet Timesheet        @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  project   TimesheetProject @relation(fields: [projectId], references: [id])
  task      TimesheetTask?   @relation(fields: [taskId], references: [id])

  @@index([tenantId])
  @@index([timesheetId])
  @@index([employeeId])
}

model TimesheetSettings {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  standardWeeklyHours    Float    @default(40)
  overtimeThresholdHours Float    @default(40)
  roundingMinutes        Int      @default(15)
  approvalRequired       Boolean  @default(true)
  unloggedHoursPolicy    String   @default("FLAG") // IGNORE | FLAG | DEDUCT
  billableDefault        Boolean  @default(true)
  // M7 — ISO weekday (Mon=1 .. Sun=7) on which the submit-reminder job nudges
  // employees/managers about unsubmitted prior weeks. null = reminders disabled.
  submitReminderDay      Int?
  // M2 — when true, POST/PATCH /timesheets/entries reject an entry with no taskId (422).
  requireTaskOnEntry     Boolean  @default(false)
  updatedAt              DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Per-user saved weekly template — a named set of rows reused across weeks (UI PR #9).
// `rows` is JSON-encoded TemplateRow[] (matches the memberIds-as-JSON convention):
//   [{ projectId: string, taskId: string|null, hoursByWeekday: number[7] /* Mon→Sun */ }]
model TimesheetTemplate {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  name       String
  rows       String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
}

// ── Payroll Phase 3 Extended Models ────────────────────────────────────────────

model ReimbursementCategory {
  id         String   @id @default(cuid())
  tenantId   String
  code       String
  label      String
  monthlyCap Decimal  @default(0) @db.Decimal(15, 2)
  createdAt  DateTime @default(now())

  claims ReimbursementClaim[]
  tenant Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ReimbursementClaim {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  categoryId  String
  amount      Decimal   @db.Decimal(15, 2)
  currency    String    @default("INR")
  description String?
  proofUrl    String?
  status      String    @default("SUBMITTED") // SUBMITTED | APPROVED | REJECTED | PAID
  runId       String?
  submittedAt DateTime  @default(now())
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category ReimbursementCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, status])
}

model Garnishment {
  id                     String   @id @default(cuid())
  tenantId               String
  employeeId             String
  type                   String // CHILD_SUPPORT | SPOUSAL_SUPPORT | TAX_LEVY | COURT_ORDER | DEFAULTED_LOAN
  priority               Int      @default(1)
  amountKind             String   @default("FLAT") // FLAT | PERCENT_OF_DISPOSABLE
  amountValue            Decimal  @db.Decimal(15, 2)
  protectedEarningsFloor Decimal  @default(0) @db.Decimal(15, 2)
  cap                    Decimal? @db.Decimal(15, 2)
  reference              String?
  effectiveFrom          String
  effectiveTo            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
}

model ContractorInvoice {
  id             String    @id @default(cuid())
  tenantId       String
  workerId       String
  workerName     String
  period         String
  amount         Decimal   @db.Decimal(15, 2)
  currency       String    @default("USD")
  withholdingPct Decimal   @default(0) @db.Decimal(5, 2)
  netPayable     Decimal   @db.Decimal(15, 2)
  status         String    @default("SUBMITTED") // SUBMITTED | APPROVED | PAID | VOIDED
  payoutRef      String?
  submittedAt    DateTime  @default(now())
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, workerId])
  @@index([tenantId, status])
}

model PaymentBatch {
  id           String    @id @default(cuid())
  tenantId     String
  runId        String
  count        Int       @default(0)
  totalAmount  Decimal   @default(0) @db.Decimal(15, 2)
  currency     String    @default("INR")
  status       String    @default("PENDING") // PENDING | PROCESSING | COMPLETED
  linesJson    Json      @default("[]")
  createdAt    DateTime  @default(now())
  reconciledAt DateTime?
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([runId])
}

model PayrollEvent {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  runId     String?
  summary   String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, runId])
}

model PayslipTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  name      String   @default("Default Payslip")
  locale    String   @default("en-IN")
  logoUrl   String?
  sections  Json     @default("[]")
  fields    Json     @default("[]")
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UserInvitation {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  userId       String
  tokenHash    String    @unique
  emailTarget  String    // PERSONAL | WORK
  email        String    // actual email address the invite was sent to
  expiresAt    DateTime
  usedAt       DateTime?
  revokedAt    DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user      User     @relation("invitedUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("inviteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([employeeId])
  @@index([tokenHash])
  @@index([tenantId, userId, usedAt, revokedAt])
}
